                    "name": "Register User",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 201', function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "pm.test('Response has success message', function () {",
                                    "    var json = pm.response.json();",
                                    "    pm.expect(json.message).to.eql('User registered successfully');",
                                    "});"
